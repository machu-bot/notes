---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}
const { title, description = 'Personal learning notes' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const home = base ? `${base}/` : '/';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — notes</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#000000" />
  </head>
  <body>
    <div class="container">
      <nav class="top">
        <a href={home} class="brand">notes<span style="color:var(--accent)">.</span></a>
        <span class="label">learning log</span>
      </nav>
      <slot />
    </div>
  </body>
</html>
