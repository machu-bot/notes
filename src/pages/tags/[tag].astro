---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';

export async function getStaticPaths() {
  const posts = await getCollection('posts');
  const HIDDEN = new Set(['published']);

  // Collect every non-hidden label across all posts and emit one page per label.
  const labelToPosts = new Map<string, typeof posts>();
  for (const post of posts) {
    for (const label of post.data.labels) {
      if (HIDDEN.has(label)) continue;
      if (!labelToPosts.has(label)) labelToPosts.set(label, []);
      labelToPosts.get(label)!.push(post);
    }
  }

  return Array.from(labelToPosts.entries()).map(([label, tagged]) => ({
    params: { tag: label },
    props: {
      tag: label,
      posts: tagged.sort(
        (a, b) => b.data.createdAt.getTime() - a.data.createdAt.getTime()
      ),
      counts: Object.fromEntries(
        Array.from(labelToPosts.entries()).map(([k, v]) => [k, v.length])
      ) as Record<string, number>,
    },
  }));
}

const { tag, posts, counts } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

// All known tags, sorted by frequency desc then alpha, for the sidebar / footer.
const allTags = Object.entries(counts).sort(
  (a, b) => b[1] - a[1] || a[0].localeCompare(b[0])
);
---
<Base title={`#${tag}`}>
  <a class="back" href={`${base}/`}>← back</a>
  <header style="margin-bottom:32px">
    <h1>#{tag}<span style="color:var(--accent)">.</span></h1>
    <p class="label" style="margin-top:8px">
      {posts.length} post{posts.length === 1 ? '' : 's'}
    </p>
  </header>

  {allTags.length > 1 && (
    <nav class="tag-row" style="margin-bottom:32px">
      {allTags.map(([t, n]) => (
        <a
          class="tag"
          href={`${base}/tags/${encodeURIComponent(t)}/`}
          style={t === tag ? 'border-color:var(--accent);color:var(--accent)' : ''}
        >
          #{t} <span style="opacity:.5">·{n}</span>
        </a>
      ))}
    </nav>
  )}

  <div class="post-list">
    {posts.map((post) => (
      <article class="post-item">
        <div style="flex:1;min-width:0">
          <a href={`${base}/posts/${post.id}/`} class="title">{post.data.title}</a>
        </div>
        <div class="meta">
          <span class="unit">#{post.data.issue}</span>
          <time class="label" datetime={post.data.createdAt.toISOString()}>
            {post.data.createdAt.toISOString().slice(0, 10)}
          </time>
        </div>
      </article>
    ))}
  </div>
</Base>
